# Travel Planner Backend - Environment Variables Template
# Copy this file to .env and fill in your values

# Application
APP_NAME=travel-planner-backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# PDF Playwright render (FIX #236) — token 5 min, wspólny secret z frontendem Next.js
FRONTEND_BASE_URL=https://lets-travel.pl
PDF_RENDER_JWT_SECRET=generate-a-long-random-secret-shared-with-frontend
PDF_RENDER_TOKEN_TTL_SEC=300
PDF_RENDER_WAIT_TIMEOUT_MS=20000
PDF_PLAYWRIGHT_ENABLED=true
# PDF_RENDER_ALLOWED_HOSTS=preview.lets-travel.pl

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key_here
GEOCODING_API_KEY=your_geocoding_api_key_here

# OpenRouteService (FIX #220) — free tier: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here
ORS_ENABLED=false
ORS_ROUTING_ENABLED=true
ORS_MATRIX_ENABLED=true
ORS_POI_SUPPLEMENT_ENABLED=false
ORS_CACHE_TTL_DAYS=60
ORS_DAILY_BUDGET_DIRECTIONS=1500
ORS_DAILY_BUDGET_MATRIX=120
ORS_MATRIX_MAX_LOCATIONS=8
ORS_OVERPASS_RADIUS_M=2500
# Optional: persistent route cache directory (default .cache/ors_routes)
# ORS_CACHE_DIR=.cache/ors_routes

# ============================================
# SUPABASE (ETAP 2) - Auth & Database
# ============================================
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Verification (choose ONE based on your Supabase JWT algorithm)
# For ES256 (recommended, default for new projects):
# Get from: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret (copy public key)
SUPABASE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE...\n-----END PUBLIC KEY-----"

# For HS256 (legacy, older projects):
# Get from: Supabase Dashboard → Settings → API → Project API keys → JWT Secret (legacy)
SUPABASE_JWT_SECRET=your-jwt-secret-from-legacy-jwt-secret

# Database (ETAP 2 - PostgreSQL on Supabase)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI, Pooler)
DATABASE_URL=postgresql://postgres.your-project-id:password@aws-region.pooler.supabase.com:6543/postgres

# ============================================
# STRIPE (ETAP 2) - Payment Processing
# ============================================
# Get from: Stripe Dashboard → Developers → API keys (Test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: Stripe Dashboard → Products → Create product (39.99 PLN one-time)
STRIPE_PRICE_ID=price_...
# Get from: Stripe Dashboard → Developers → Webhooks (after backend deployment)
STRIPE_WEBHOOK_SECRET=whsec_...

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Data
POI_DATA_PATH=data/zakopane.xlsx
